# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://salon_pos:salon_pos_secret@localhost:5432/salon_pos?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:8080

# Salon defaults (for single-tenant mode)
DEFAULT_SALON_ID=
